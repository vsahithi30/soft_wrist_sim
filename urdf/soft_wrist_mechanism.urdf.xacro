<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="soft_wrist">

  <xacro:macro name="soft_wrist_mechanism" params="prefix parent *origin">

    <joint name="${prefix}tool0_to_soft_wrist_base" type="fixed">
      <xacro:insert_block name="origin"/>
      <parent link="${parent}"/>
      <child link="${prefix}sw_base"/>
    </joint>

    <!-- Full mechanism as single merged mesh — no splitting ever -->
    <link name="${prefix}sw_base">
      <inertial>
        <mass value="0.1"/>
        <inertia ixx="0.0001" ixy="0" ixz="0"
                 iyy="0.0001" iyz="0" izz="0.0001"/>
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://soft_wrist_sim/meshes/soft_wrist_new.stl"/>
        </geometry>
        <material name="light_blue">
          <color rgba="0.529 0.808 0.922 1"/>
        </material>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry><box size="0.08 0.08 0.08"/></geometry>
      </collision>
    </link>

    <!-- CB1 revolute joint (actuated, no visual) -->
    <joint name="${prefix}CB1" type="revolute">
      <origin xyz="0.02574 0.01332 0.00773"
              rpy="1.5707963267949 0.00810834307320704 2.09439510239321"/>
      <parent link="${prefix}sw_base"/>
      <child link="${prefix}sw_CB1"/>
      <axis xyz="0 0 -1"/>
      <limit lower="-0.785" upper="0.785" effort="1.8" velocity="3.14"/>
      <dynamics damping="100.0" friction="10.0"/>
    </joint>
    <link name="${prefix}sw_CB1">
      <inertial>
        <mass value="0.003"/>
        <inertia ixx="1.803e-07" ixy="0" ixz="0"
                 iyy="9.612e-08" iyz="0" izz="2.442e-07"/>
      </inertial>
    </link>

    <!-- CB2 revolute joint (actuated, no visual) -->
    <joint name="${prefix}CB2" type="revolute">
      <origin xyz="0.00149 -0.02868 0.00773" rpy="1.5708 -0.051062 0"/>
      <parent link="${prefix}sw_base"/>
      <child link="${prefix}sw_CB2"/>
      <axis xyz="0 0 -1"/>
      <limit lower="-0.785" upper="0.785" effort="1.8" velocity="3.14"/>
      <dynamics damping="100.0" friction="10.0"/>
    </joint>
    <link name="${prefix}sw_CB2">
      <inertial>
        <mass value="0.003"/>
        <inertia ixx="1.801e-07" ixy="0" ixz="0"
                 iyy="9.633e-08" iyz="0" izz="2.442e-07"/>
      </inertial>
    </link>

    <!-- CB3 revolute joint (actuated, no visual) -->
    <joint name="${prefix}CB3" type="revolute">
      <origin xyz="-0.02275 0.01332 0.00773"
              rpy="1.5707963267949 0.0429714560028375 -2.09439510239319"/>
      <parent link="${prefix}sw_base"/>
      <child link="${prefix}sw_CB3"/>
      <axis xyz="0 0 -1"/>
      <limit lower="-0.785" upper="0.785" effort="1.8" velocity="3.14"/>
      <dynamics damping="100.0" friction="10.0"/>
    </joint>
    <link name="${prefix}sw_CB3">
      <inertial>
        <mass value="0.003"/>
        <inertia ixx="1.802e-07" ixy="0" ixz="0"
                 iyy="9.627e-08" iyz="0" izz="2.442e-07"/>
      </inertial>
    </link>

  </xacro:macro>

</robot>
